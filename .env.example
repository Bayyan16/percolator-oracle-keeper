# Required
RPC_URL=https://api.devnet.solana.com

# Keypair — one of these required:
# ADMIN_KEYPAIR=[1,2,3,...] (JSON array of 64 bytes — for Railway/Docker deployments)
# ADMIN_KEYPAIR_PATH=/home/user/.config/solana/keypair.json (file path)

# Optional — Supabase auto-discovery (enables dynamic market tracking)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Optional — Deployment JSON (if not using Supabase auto-discovery)
DEPLOYMENT_JSON=

# Optional — Tuning
PUSH_INTERVAL_MS=3000
HEALTH_PORT=18810
HEALTH_BIND=0.0.0.0
HEALTH_AUTH_TOKEN=your-secure-bearer-token
MAX_PRICE_MOVE_PCT=10
PYTH_MAX_CONFIDENCE_PCT=10
STALE_THRESHOLD_S=30
MIN_KEEPER_BALANCE_SOL=0.05
ORACLE_KEEPER_BLOCKED_MARKETS=

# Optional — Price feeds
HERMES_URL=https://hermes.pyth.network
DISCOVERY_INTERVAL_MS=30000
